# تنظیمات API تلگرام
API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# ادمین‌های ربات (با کاما جدا کنید)
ADMIN_IDS=123456789,987654321

# مسیرها
SESSIONS_DIR=sessions
LOGS_DIR=logs
DATABASE_PATH=data/accounts.db

# تنظیمات تایمر
DELAY_BETWEEN_ACTIONS=5
DELAY_RANDOM_RANGE=3
MAX_ACTIONS_PER_MINUTE=10

# پروکسی (اختیاری)
PROXY_ENABLED=false
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=1080
PROXY_USERNAME=
PROXY_PASSWORD=
